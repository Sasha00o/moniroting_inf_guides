# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_USER_IDS=123456789,987654321

# AI Provider: gemini | claude | openai | groq | deepseek | openrouter
# Для продакшена рекомендуется:
# - openai (gpt-4o-mini) - быстрый, качественный, $0.15/$0.60 за 1M токенов
# - gemini (gemini-2.0-flash-exp) - бесплатный tier до 1500 req/day, потом платный
AI_PROVIDER=openai

GEMINI_API_KEY=your_gemini_key
CLAUDE_API_KEY=your_claude_key
OPENAI_API_KEY=your_openai_key
GROQ_API_KEY=your_groq_key
DEEPSEEK_API_KEY=your_deepseek_key
OPENROUTER_API_KEY=your_openrouter_key

# Google Services
# Выберите один из методов авторизации:
# 1. OAuth 2.0 (рекомендуется для личного использования)
GOOGLE_OAUTH_CREDENTIALS=credentials/oauth_credentials.json
# 2. Service Account (для серверных приложений)
# GOOGLE_SERVICE_ACCOUNT_FILE=credentials/google_service_account.json

GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

SCHEDULE_CRON=0 9 */3 * *

MODE=PROD
LOG_LEVEL=INFO

# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_BASE_URL=https://api.groq.com/openai/v1
