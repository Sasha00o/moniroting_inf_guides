#  Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_USER_IDS=123456789,987654321

# AI Provider (выбрать один: gemini / claude / openai)
AI_PROVIDER=gemini

# Заполнить ключ только для выбранного провайдера
GEMINI_API_KEY=your_gemini_key
CLAUDE_API_KEY=your_claude_key
OPENAI_API_KEY=your_openai_key


# Google Services
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/google_service_account.json

# Scheduler (cron: минута час день месяц день_недели)
SCHEDULE_CRON=0 9 */3 * *

# Application
MODE=DEV
LOG_LEVEL=INFO

# AI Models (опционально, есть значения по умолчанию в config.py)
# CLAUDE_MODEL=claude-3-5-haiku-20241022
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-1.5-flash

# News & Report limits (опционально)
# NEWS_DAYS_BACK=7
# NEWS_MAX_ITEMS=50
# INFOREASONS_MIN=10
# INFOREASONS_MAX=20
